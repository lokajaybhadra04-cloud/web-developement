
<%- include("includes/head.ejs"); %> 


<body>

    <!-- instaData is object contain all data send by data.json file but 
     we want only some selected data only based on username  -->

    <h2>this page  belongs to @<%= instaData.name %>  </h2>
<!-- 
    //it give ReferenceError:

//"username" is not defined in instagram.ejs 

// As 

//we donot have render the "username" variable in the  index.js file we comment it out

//we need delete that "username " varible in instagram.ejs file 
&&
//Also delete unorder list

-->

    <button>Follow</button>
    <button>Message</button>



    <p>Followers : <%= instaData.followers %>
    &nbsp;&nbsp;&nbsp;
    Following : <%= instaData.following %></p>

<hr>
<h3>POSTS:</h3>
<%for (post of instaData.posts){%>

    <img src="<%= post.image%>" alt="pic">

    <p>LIKES : <%= post.likes%></p>

    <p>COMMENTS : <%= post.comments%></p>

<% } %>
    



<%- include("includes/footer.ejs"); %> 



</body>
<script src="/app.js"></script>
</html>